{
	"name": "n8n-nodes-acme",
	"version": "0.1.1",
	"description": "n8n community nodes for ACME certificate automation with multi-provider DNS management",
	"license": "MIT",
	"homepage": "https://github.com/kboykov/n8n-nodes-acme#readme",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"acme",
		"certificate",
		"ssl",
		"tls",
		"letsencrypt",
		"dns",
		"cloudflare",
		"dns-01"
	],
	"author": {
		"name": "kboykov",
		"email": "kboykov@protonmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kboykov/n8n-nodes-acme.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"provenance": true
	},
	"release-it": {
		"npm": {
			"publish": false
		}
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/CloudflareDnsApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/DNS/Dns.node.js",
			"dist/nodes/ACME/Acme.node.js",
			"dist/nodes/Certificate/Certificate.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^25.0.8",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"acme-client": "^5.4.0"
	}
}
